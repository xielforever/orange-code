{
  "name": "orange-desktop",
  "description": "Orange Desktop Client with Rust backend",
  "author": "xielforever",
  "repository": "https://github.com/xielforever/orange-code",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 &amp;&amp; tsc -p electron/tsconfig.json &amp;&amp; electron .",
    "build": "tsc &amp;&amp; vite build &amp;&amp; tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "pack:win": "electron-builder --win --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.orange.desktop",
    "productName": "Orange",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../rust/target/release/",
        "to": "bin/",
        "filter": [
          "orange",
          "orange.exe"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "7.3.1",
    "wait-on": "^9.0.4"
  }
}
